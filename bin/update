#!/bin/zsh

set -e

TITLE='\033[0;32m\033[1m'
GRAY='\033[0;90m'
NC='\033[0m'

echo -e "${TITLE}–Ю–±–љ–Њ–≤–ї–µ–љ–Є–µ —Б–Є—Б—В–µ–Љ—Л${NC}"
pkexec dnf update --refresh -y

echo -e "\n${TITLE}–Ю–±–љ–Њ–≤–ї–µ–љ–Є–µ –њ—А–Є–ї–Њ–ґ–µ–љ–Є–є –Є–Ј Flatpak${NC}"
flatpak update -y

echo -e "\n${TITLE}–Ю–±–љ–Њ–≤–ї–µ–љ–Є–µ Dev Container${NC}"
cd ~/.local/lib/node
npm update
~/Projects/environment/bin/update-dockerfile

echo -e "\n${TITLE}–Ю–±–љ–Њ–≤–ї–µ–љ–Є–µ —В–µ–Љ—Л Firefox${GRAY}"
cd ~/.config/mozilla/firefox/iesxdh6c.default-release/chrome/firefox-gnome-theme
git pull origin master

echo -e "\n${TITLE}–Ю–±–љ–Њ–≤–ї–µ–љ–Є–µ —А–∞—Б—И–Є—А–µ–љ–Є–є GNOME${GRAY}"
gdbus call --session --dest org.gnome.Shell.Extensions \
     --object-path /org/gnome/Shell/Extensions \
     --method org.gnome.Shell.Extensions.CheckForUpdates

echo -e "\n${TITLE}–У–Њ—В–Њ–≤–Њ${NC}"
read
